  "quotes": [
    {
      "id": "krishna_q1",
      "text": "భక్తి ఉన్న చోటే భగవంతుడు ఉంటాడు 🙏",
      "godName": "Krishna"
    },
    {
      "id": "krishna_q2",
      "text": "హరే కృష్ణ హరే రామ 🙏",
      "godName": "Krishna"
    },
    {
      "id": "krishna_q3",
      "text": "గోవిందా గోవిందా శ్రీ కృష్ణ గోవిందా 🙏",
      "godName": "Krishna"
    },
    {
      "id": "shiva_q1",
      "text": "ఓం నమః శివాయ 🙏",
      "godName": "Shiva"
    },
    {
      "id": "shiva_q2",
      "text": "హర హర మహాదేవ 🙏",
      "godName": "Shiva"
    },
    {
      "id": "shiva_q3",
      "text": "శంభో శంకర దేవాది దేవ 🙏",
      "godName": "Shiva"
    },
    {
      "id": "ganesha_q1",
      "text": "గణపతి బప్పా మోరియా 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "ganesha_q2",
      "text": "శ్రీ గణేశాయ నమః 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "ganesha_q3",
      "text": "విఘ్నేశ్వరుని అనుగ్రహంతో జీవితం సుఖమవుతుంది 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "hanuman_q1",
      "text": "జై హనుమాన్ జ్ఞాన గుణ సాగర 🙏",
      "godName": "Hanuman"
    },
    {
      "id": "hanuman_q2",
      "text": "ఆంజనేయాయ నమః 🙏",
      "godName": "Hanuman"
    },
    {
      "id": "lakshmi_q1",
      "text": "శ్రీ మహాలక్ష్మ్యై నమః 🙏",
      "godName": "Lakshmi"
    },
    {
      "id": "lakshmi_q2",
      "text": "జయ జయ లక్ష్మి అమ్మా 🙏",
      "godName": "Lakshmi"
    },
    {
      "id": "murugan_q1",
      "text": "శరవణభవ 🙏",
      "godName": "Murugan"
    },
    {
      "id": "murugan_q2",
      "text": "శ్రీ సుబ్రహ్మణ్యేశ్వరుని జయం 🙏",
      "godName": "Murugan"
    }
  ],
