  "quotes": [
    {
      "id": "krishna_q1",
      "text": "భక్తి ఉన్న చోటే భగవంతుడు ఉంటాడు 🙏",
      "godName": "Krishna"
    },
    {
      "id": "krishna_q2",
      "text": "హరే కృష్ణ హరే రామ 🙏",
      "godName": "Krishna"
    },
    {
      "id": "krishna_q3",
      "text": "గోవిందా గోవిందా శ్రీ కృష్ణ గోవిందా 🙏",
      "godName": "Krishna"
    },
    {
      "id": "shiva_q1",
      "text": "ఓం నమః శివాయ 🙏",
      "godName": "Shiva"
    },
    {
      "id": "shiva_q2",
      "text": "హర హర మహాదేవ 🙏",
      "godName": "Shiva"
    },
    {
      "id": "shiva_q3",
      "text": "శంభో శంకర దేవాది దేవ 🙏",
      "godName": "Shiva"
    },
    {
      "id": "ganesha_q1",
      "text": "గణపతి బప్పా మోరియా 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "ganesha_q2",
      "text": "శ్రీ గణేశాయ నమః 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "ganesha_q3",
      "text": "విఘ్నేశ్వరుని అనుగ్రహంతో జీవితం సుఖమవుతుంది 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "hanuman_q1",
      "text": "జై హనుమాన్ జ్ఞాన గుణ సాగర 🙏",
      "godName": "Hanuman"
    },
    {
      "id": "hanuman_q2",
      "text": "ఆంజనేయాయ నమః 🙏",
      "godName": "Hanuman"
    },
    {
      "id": "lakshmi_q1",
      "text": "శ్రీ మహాలక్ష్మ్యై నమః 🙏",
      "godName": "Lakshmi"
    },
    {
      "id": "lakshmi_q2",
      "text": "జయ జయ లక్ష్మి అమ్మా 🙏",
      "godName": "Lakshmi"
    },
    {
      "id": "murugan_q1",
      "text": "శరవణభవ 🙏",
      "godName": "Murugan"
    },
    {
      "id": "murugan_q2",
      "text": "శ్రీ సుబ్రహ్మణ్యేశ్వరుని జయం 🙏",
      "godName": "Murugan"
    },
    {
      "id": "narasimha_q1",
      "text": "ఓం నమో నారసింహాయ 🙏",
      "godName": "Narasimha"
    },
    {
      "id": "narasimha_q2",
      "text": "నారసింహ స్వామి భక్తులను సదా రక్షిస్తాడు 🙏",
      "godName": "Narasimha"
    },
    {
      "id": "narasimha_q3",
      "text": "ఉగ్ర నారసింహుని కృపతో శత్రువులు తొలగిపోతారు 🙏",
      "godName": "Narasimha"
    },
    {
      "id": "narasimha_q4",
      "text": "లక్ష్మీ నారసింహ స్వామికి నమస్కారం 🙏",
      "godName": "Narasimha"
    },
    {
      "id": "narasimha_q5",
      "text": "జయ జయ నారసింహ దేవా 🙏",
      "godName": "Narasimha"
    },
    {
      "id": "saibaba_q1",
      "text": "సాయిబాబా చరణాలే నా శరణు 🙏",
      "godName": "SaiBaba"
    },
    {
      "id": "saibaba_q2",
      "text": "శిర్డీ సాయి నాథుని అనుగ్రహం సదా కావాలి 🙏",
      "godName": "SaiBaba"
    },
    {
      "id": "saibaba_q3",
      "text": "సబ్కా మాలిక్ ఏక్ — సాయిబాబా 🙏",
      "godName": "SaiBaba"
    },
    {
      "id": "saibaba_q4",
      "text": "సాయి నాథుని భక్తితో జీవితం ధన్యమవుతుంది 🙏",
      "godName": "SaiBaba"
    },
    {
      "id": "saibaba_q5",
      "text": "ఓం సాయి రామ్ — సాయిబాబాకు జయం 🙏",
      "godName": "SaiBaba"
    },
    {
      "id": "krishna_q4",
      "text": "నీ కర్మ చేయి — ఫలితం కృష్ణుడి దే 🙏",
      "godName": "Krishna"
    },
    {
      "id": "krishna_q5",
      "text": "కృష్ణుడి పేరు పలికితే మనసుకు శాంతి లభిస్తుంది 🙏",
      "godName": "Krishna"
    },
    {
      "id": "krishna_q6",
      "text": "గోవింద నామమే జీవితం నిలబెడుతుంది 🙏",
      "godName": "Krishna"
    },

    {
      "id": "shiva_q4",
      "text": "శివుని స్మరణలోనే నిజమైన శాంతి 🙏",
      "godName": "Shiva"
    },
    {
      "id": "shiva_q5",
      "text": "శివుడు ఉన్నచోట భయం ఉండదు 🙏",
      "godName": "Shiva"
    },
    {
      "id": "shiva_q6",
      "text": "మహాదేవుని కృపతో కష్టాలు కరిగిపోతాయి 🙏",
      "godName": "Shiva"
    },

    {
      "id": "ganesha_q4",
      "text": "వినాయకుడి ఆశీర్వాదం తో ప్రతి ప్రారంభం విజయమే 🙏",
      "godName": "Ganesha"
    },
    {
      "id": "ganesha_q5",
      "text": "గణపతి పేరు ఉన్నచోట అడ్డంకులు ఉండవు 🙏",
      "godName": "Ganesha"
    },

    {
      "id": "hanuman_q3",
      "text": "జై శ్రీరామ్ అన్నచోట హనుమంతుడు ఉంటాడు 🙏",
      "godName": "Hanuman"
    },
    {
      "id": "hanuman_q4",
      "text": "హనుమంతుడి భక్తి ధైర్యానికి మూలం 🙏",
      "godName": "Hanuman"
    },

    {
      "id": "lakshmi_q3",
      "text": "లక్ష్మీ కటాక్షం ఉన్నచోట సమృద్ధి ఉంటుంది 🙏",
      "godName": "Lakshmi"
    },
    {
      "id": "lakshmi_q4",
      "text": "శుభ్రత ఉన్నచోటే లక్ష్మీ నివసిస్తుంది 🙏",
      "godName": "Lakshmi"
    },

    {
      "id": "murugan_q3",
      "text": "సుబ్రహ్మణ్య స్వామి దయతో భయం దూరమవుతుంది 🙏",
      "godName": "Murugan"
    },
    {
      "id": "murugan_q4",
      "text": "శరవణభవ నామం శక్తిని నింపుతుంది 🙏",
      "godName": "Murugan"
    },

    {
      "id": "narasimha_q6",
      "text": "నారసింహ స్వామి భక్తుని ఎప్పుడూ కాపాడుతాడు 🙏",
      "godName": "Narasimha"
    },
    {
      "id": "narasimha_q7",
      "text": "ఉగ్ర నారసింహుడు శత్రువులపై విజయం ఇస్తాడు 🙏",
      "godName": "Narasimha"
    },

    {
      "id": "saibaba_q6",
      "text": "సాయి నామమే శరణ్యం 🙏",
      "godName": "SaiBaba"
    },
    {
      "id": "saibaba_q7",
      "text": "సాయి కృప ఉంటే జీవితం సులభం అవుతుంది 🙏",
      "godName": "SaiBaba"
    },

    {
      "id": "rama_q1",
      "text": "జై శ్రీరామ్ — ధర్మానికి జయం 🙏",
