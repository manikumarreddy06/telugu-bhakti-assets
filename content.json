   "quotes_bhagavad_gita":[
      {
         "id":"gita_q1",
         "text":"కర్మణ్యేవాధికారస్తే మా ఫలేషు కదాచన",
         "godName":"Krishna",
         "source":"Bhagavad Gita 2.47"
      },
      {
         "id":"gita_q2",
         "text":"యదా యదా హి ధర్మస్య గ్లానిర్భవతి భారత",
         "godName":"Krishna",
         "source":"Bhagavad Gita 4.7"
      },
      {
         "id":"gita_q3",
         "text":"పరిత్రాణాయ సాధూనాం వినాశాయ చ దుష్కృతామ్",
         "godName":"Krishna",
         "source":"Bhagavad Gita 4.8"
      },
      {
         "id":"gita_q4",
         "text":"సర్వధర్మాన్ పరిత్యజ్య మామేకం శరణం వ్రజ",
         "godName":"Krishna",
         "source":"Bhagavad Gita 18.66"
      },
      {
         "id":"gita_q5",
         "text":"వాసాంసి జీర్ణాని యథా విహాయ నవాని గృహ్ణాతి నరోఽపరాణి",
         "godName":"Krishna",
         "source":"Bhagavad Gita 2.22"
      },
      {
         "id":"gita_q6",
         "text":"నైనం ఛిందంతి శస్త్రాణి నైనం దహతి పావకః",
         "godName":"Krishna",
         "source":"Bhagavad Gita 2.23"
      },
      {
         "id":"gita_q7",
         "text":"హతో వా ప్రాప్స్యసి స్వర్గం జిత్వా వా భోక్ష్యసే మహీమ్",
         "godName":"Krishna",
         "source":"Bhagavad Gita 2.37"
      },
      {
         "id":"gita_q8",
         "text":"యోగస్థః కురు కర్మాణి సంగం త్యక్త్వా ధనంజయ",
         "godName":"Krishna",
         "source":"Bhagavad Gita 2.48"
      },
      {
         "id":"gita_q9",
         "text":"బుద్ధియుక్తో జహాతీహ ఉభే సుకృతదుష్కృతే",
         "godName":"Krishna",
         "source":"Bhagavad Gita 2.50"
      },
      {
         "id":"gita_q10",
         "text":"అహం సర్వస్య ప్రభవో మత్తః సర్వం ప్రవర్తతే",
         "godName":"Krishna",
         "source":"Bhagavad Gita 10.8"
      }
   ],
   "quotes_ramayana":[
      {
         "id":"rama_q3",
         "text":"ఆపదాం కథితః పంథా ఇంద్రియాణామసంయమః",
         "godName":"Rama",
         "source":"Valmiki Ramayana"
      },
      {
         "id":"rama_q4",
         "text":"సత్యమేవ జయతే నానృతం",
         "godName":"Rama",
         "source":"Mundaka Upanishad"
      },
      {
         "id":"rama_q5",
         "text":"ధర్మ ఏవ హతో హంతి ధర్మో రక్షతి రక్షితః",
         "godName":"Rama",
         "source":"Manusmriti / Ramayana essence"
      },
      {
         "id":"hanuman_q5",
         "text":"మనోజవం మారుతతుల్యవేగం జితేంద్రియం బుద్ధిమతాం వరిష్ఠమ్",
         "godName":"Hanuman",
         "source":"Hanuman Chalisa / Ramayana"
      },
      {
         "id":"hanuman_q6",
         "text":"బుద్ధిహీన తనుజానికే సుమిరౌ పవనకుమార",
         "godName":"Hanuman",
         "source":"Hanuman Chalisa"
      },
      {
         "id":"hanuman_q7",
         "text":"భూత పిశాచ నికట నహిం ఆవై మహావీర జప నామ సునావై",
         "godName":"Hanuman",
         "source":"Hanuman Chalisa"
      },
      {
         "id":"rama_q6",
         "text":"రామో విగ్రహవాన్ ధర్మః",
         "godName":"Rama",
         "source":"Valmiki Ramayana"
      },
      {
         "id":"rama_q7",
         "text":"రఘుకుల రీతి సదా చలి ఆయీ ప్రాణ జాయీ పర వచన న జాయీ",
         "godName":"Rama",
         "source":"Ramcharitmanas"
      }
   ],
   "quotes_upanishads":[
      {
         "id":"upanishad_q1",
         "text":"సత్యమేవ జయతే",
         "godName":"Durga",
         "source":"Mundaka Upanishad 3.1.6"
      },
      {
         "id":"upanishad_q2",
         "text":"అసతో మా సద్గమయ | తమసో మా జ్యోతిర్గమయ | మృత్యోర్మా అమృతం గమయ",
         "godName":"Shiva",
         "source":"Brihadaranyaka Upanishad"
      },
      {
         "id":"upanishad_q3",
         "text":"అహం బ్రహ్మాస్మి",
         "godName":"Shiva",
         "source":"Brihadaranyaka Upanishad"
      },
      {
         "id":"upanishad_q4",
         "text":"తత్ త్వమ్ అసి",
         "godName":"Vishnu",
         "source":"Chandogya Upanishad"
      },
      {
         "id":"upanishad_q5",
         "text":"ఏకం సత్ విప్రా బహుధా వదంతి",
         "godName":"Krishna",
         "source":"Rig Veda"
      }
   ],
   "quotes_mahabharata":[
      {
         "id":"mahabharata_q1",
         "text":"అహింసా పరమో ధర్మః",
         "godName":"Krishna",
         "source":"Mahabharata"
      },
      {
         "id":"mahabharata_q2",
         "text":"ధర్మో రక్షతి రక్షితః",
         "godName":"Krishna",
         "source":"Mahabharata"
      },
      {
         "id":"mahabharata_q3",
         "text":"ఆత్మానం సతతం రక్షేత్ స్వధర్మమనుపాలయన్",
         "godName":"Krishna",
         "source":"Mahabharata"
      },
      {
         "id":"mahabharata_q4",
         "text":"యతో ధర్మః తతో జయః",
         "godName":"Krishna",
         "source":"Mahabharata"
      },
      {
         "id":"mahabharata_q5",
         "text":"అశ్వత్థామా హతః ఇతి నరో వా కుంజరో వా",
         "godName":"Krishna",
         "source":"Mahabharata"
      }
   ],
   "quotes_puranas":[
      {
         "id":"vishnu_q1",
         "text":"శాంతాకారం భుజగశయనం పద్మనాభం సురేశం",
         "godName":"Vishnu",
         "source":"Vishnu Sahasranama"
      },
      {
         "id":"shiva_q7",
         "text":"కర్పూర గౌరం కరుణావతారం",
         "godName":"Shiva",
         "source":"Shiva Stotram"
      },
      {
         "id":"durga_q1",
         "text":"సర్వమంగళ మాంగల్యే శివే సర్వార్థ సాధికే",
         "godName":"Durga",
         "source":"Devi Mahatmya"
      },
      {
         "id":"durga_q2",
         "text":"యా దేవీ సర్వభూతేషు శక్తి రూపేణ సంస్థితా",
         "godName":"Durga",
         "source":"Devi Mahatmya"
      },
      {
         "id":"durga_q3",
         "text":"జయంతి మంగళ కాళీ భద్రకాళీ కపాలినీ",
         "godName":"Durga",
         "source":"Devi Mahatmya"
      },
      {
         "id":"lakshmi_q5",
         "text":"నమస్తేస్తు మహామాయే శ్రీపీఠే సురపూజితే",
         "godName":"Lakshmi",
         "source":"Lakshmi Stotram"
      },
      {
         "id":"saraswati_q1",
         "text":"సరస్వతీ నమస్తుభ్యం వరదే కామరూపిణీ",
         "godName":"Saraswati",
         "source":"Saraswati Stotram"
      },
      {
         "id":"saraswati_q2",
         "text":"విద్యారంభం కరిష్యామి సిద్ధిర్భవతు మే సదా",
         "godName":"Saraswati",
         "source":"Saraswati Stotram"
      }
   ],
   "quotes_modern_devotional":[
      {
         "id":"rama_q8",
         "text":"శ్రీరామ జయరామ జయజయరామ",
         "godName":"Rama"
      },
      {
         "id":"krishna_q7",
         "text":"హరే రామ హరే రామ రామరామ హరే హరే",
         "godName":"Krishna"
      },
      {
         "id":"shiva_q8",
         "text":"ఓం త్రయంబకం యజామహే సుగంధిం పుష్టివర్ధనం",
         "godName":"Shiva",
         "source":"Mahamrityunjaya Mantra"
      },
      {
         "id":"ganesha_q6",
         "text":"వక్రతుండ మహాకాయ సూర్యకోటి సమప్రభ",
         "godName":"Ganesha"
      },
      {
         "id":"ganesha_q7",
         "text":"శుక్లాంబరధరం విష్ణుం శశివర్ణం చతుర్భుజం",
         "godName":"Ganesha"
      },
      {
         "id":"murugan_q5",
         "text":"ఓం షణ్ముఖాయే నమః",
         "godName":"Murugan"
      },
      {
         "id":"ayyappa_q1",
         "text":"స్వామియే శరణమయ్యప్ప",
         "godName":"Ayyappa"
      },
      {
         "id":"venkateswara_q3",
         "text":"ఓం నమో వెంకటేశాయ",
         "godName":"Venkateshwara"
      },
      {
         "id":"narasimha_q8",
         "text":"ఓం ఉగ్రం వీరం మహావిష్ణుం జ్వలంతం సర్వతోముఖం",
         "godName":"Narasimha"
      }
   ],
